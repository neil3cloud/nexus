{
  "name": "nexus",
  "displayName": "Nexus",
  "description": "Nexus VS Code extension foundation.",
  "version": "0.0.1",
  "private": true,
  "publisher": "nexus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neil3cloud/nexus.git"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "assets/nexus-icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:nexus.initializeWorkspace",
    "onCommand:nexus.discoverAdapters",
    "onCommand:nexus.dispatchAdapterRequest",
    "onCommand:nexus.showHostCapabilities",
    "onCommand:nexus.runDeveloperMissionWorkflow",
    "onCommand:nexus.runDeveloperMissionWorkflowWithGeminiCli",
    "onCommand:nexus.runDeveloperMissionWorkflowWithCodexCli",
    "onCommand:nexus.runDeveloperMissionWorkflowWithConfiguredAdapter",
    "onCommand:nexus.showMissionWorkflowHistory"
  ],
  "contributes": {
    "commands": [
      {
        "command": "nexus.initializeWorkspace",
        "title": "Nexus: Initialize Workspace"
      },
      {
        "command": "nexus.discoverAdapters",
        "title": "Nexus: Discover Adapters"
      },
      {
        "command": "nexus.dispatchAdapterRequest",
        "title": "Nexus: Dispatch Adapter Request"
      },
      {
        "command": "nexus.showHostCapabilities",
        "title": "Nexus: Show Host Capabilities"
      },
      {
        "command": "nexus.runDeveloperMissionWorkflowWithConfiguredAdapter",
        "title": "Run Developer Workflow",
        "category": "Nexus",
        "shortTitle": "Run Developer Workflow"
      },
      {
        "command": "nexus.runDeveloperMissionWorkflow",
        "title": "Run Developer Workflow (Mock Adapter Compatibility)",
        "category": "Nexus",
        "shortTitle": "Run with Mock Adapter"
      },
      {
        "command": "nexus.runDeveloperMissionWorkflowWithGeminiCli",
        "title": "Run Developer Workflow (Gemini CLI Compatibility)",
        "category": "Nexus",
        "shortTitle": "Run with Gemini CLI"
      },
      {
        "command": "nexus.runDeveloperMissionWorkflowWithCodexCli",
        "title": "Run Developer Workflow (Codex CLI Compatibility)",
        "category": "Nexus",
        "shortTitle": "Run with Codex CLI"
      },
      {
        "command": "nexus.showMissionWorkflowHistory",
        "title": "Nexus: Show Mission Workflow History"
      }
    ],
    "configuration": {
      "title": "Nexus",
      "properties": {
        "nexus.developerWorkflow.defaultAdapterId": {
          "type": "string",
          "default": "mock-adapter",
          "scope": "resource",
          "markdownDescription": "Default Adapter identifier used by the recommended **Nexus: Run Developer Workflow** command (`nexus.runDeveloperMissionWorkflowWithConfiguredAdapter`). The VS Code Host resolves this value to an explicit `adapterId` before invoking the unchanged Kernel execution pipeline."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "compile": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "package": "npm run build && vsce package --out nexus-0.0.1.vsix",
    "test": "vitest run --exclude \"test/extension-host/**\"",
    "test:extension-host:build": "node esbuild.extension-host-test.js",
    "test:extension-host": "npm run package && npm run test:extension-host:build && node out/extension-host/run-tests.js",
    "validate": "npm run compile && npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "@types/vscode": "^1.92.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "pino": "^10.3.1"
  }
}
